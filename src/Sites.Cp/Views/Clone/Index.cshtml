<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Clone — Sites CP</title>
    <style>
        :root { font-family: system-ui, sans-serif; color: #1a1a1a; }
        body { margin: 0; background: #f4f5f7; }
        header { background: #111827; color: #fff; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
        header nav a { color: #cbd5e1; text-decoration: none; margin-right: 14px; }
        header nav a.active { color: #fff; font-weight: 600; }
        header button.secondary { background: #6b7280; color: #fff; border: 0; border-radius: 6px; padding: 8px 12px; cursor: pointer; font: inherit; }
        main { max-width: 900px; margin: 24px auto; padding: 0 16px 40px; }
        .card { background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 1px 3px rgba(0,0,0,.08); margin-bottom: 16px; }
        h1 { margin: 0 0 8px; font-size: 22px; }
        h2 { margin: 0 0 12px; font-size: 18px; }
        button { background: #2563eb; color: #fff; border: 0; border-radius: 6px; padding: 8px 12px; cursor: pointer; font: inherit; }
        button.secondary { background: #6b7280; }
        button.danger { background: #dc2626; }
        input { width: 100%; box-sizing: border-box; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 6px; font: inherit; }
        label { display: block; font-size: 13px; color: #374151; margin: 10px 0 4px; }
        .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .muted { color: #6b7280; font-size: 13px; }
        .actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; align-items: center; }
        .badge { display: inline-block; background: #dbeafe; color: #1d4ed8; font-size: 12px; padding: 2px 8px; border-radius: 999px; }
        .badge.warn { background: #fef3c7; color: #92400e; }
        .badge.ok { background: #d1fae5; color: #065f46; }
        #status { min-height: 20px; margin-top: 8px; font-size: 13px; }
        #status.error { color: #b91c1c; }
        #status.ok { color: #047857; }
        pre#cloneLog { background: #111827; color: #e5e7eb; padding: 12px; border-radius: 6px; font-size: 12px; min-height: 160px; max-height: 400px; overflow: auto; white-space: pre-wrap; }
        code { font-size: 12px; background: #f3f4f6; padding: 1px 4px; border-radius: 4px; }
        ul.req { margin: 8px 0 0; padding-left: 18px; font-size: 13px; color: #6b7280; }
    </style>
</head>
<body>
@await Html.PartialAsync("_CpNav", "clone")
<main>
    <div class="card">
        <h1>Clone</h1>
        <p class="muted">Remote install over SSH from this browser (like Hephaestus CP → Clone). SSH password stays in browser cookies only.</p>
        <ul class="req">
            <li>Ubuntu 22+ with public IP</li>
            <li>1 GB RAM, 25 GB disk</li>
            <li>Installs .NET 10, clones repo, publishes <code>sites-host</code> systemd service</li>
        </ul>
        <div id="status"></div>
    </div>

    <div class="card">
        <h2>Remote install</h2>
        <p class="muted">Profile is written to <code>../profile.txt</code> (one level above the clone dir) and selects <code>profiles/{name}/sites.json</code> on the target host.</p>
        <div class="row">
            <div>
                <label for="cloneProfile">Profile <span class="muted">(required)</span></label>
                <input type="text" id="cloneProfile" value="@ViewData["Profile"]" autocomplete="off" required />
                <div class="hint">Cannot clone with profile <code>default</code> — use a dedicated name (e.g. <code>staging</code>, <code>prod-eu</code>).</div>
            </div>
            <div>
                <label for="cloneHost">Server IP / host</label>
                <input type="text" id="cloneHost" autocomplete="off" />
            </div>
        </div>
        <div class="row">
            <div>
                <label for="cloneUser">SSH user</label>
                <input type="text" id="cloneUser" autocomplete="username" />
            </div>
            <div>
                <label for="clonePassword">SSH password</label>
                <input type="password" id="clonePassword" autocomplete="current-password" />
            </div>
        </div>
        <div class="actions">
            <button type="button" id="cloneStartBtn">Start remote install</button>
            <span class="muted" id="cloneDirHint"></span>
        </div>
        <pre id="cloneLog"></pre>
    </div>

    <div class="card">
        <h2>Self-update this host</h2>
        <p class="muted">Linux only: schedules <code>deploy/update.sh</code> in its own systemd unit (git sync, then <code>install-local.sh</code> publish + restart <code>sites-host</code>). Same pattern as Hephaestus update → install.</p>
        <div class="actions">
            <button type="button" class="danger" id="selfUpdateBtn">Schedule self-update</button>
            <span id="selfUpdateHint" class="muted"></span>
        </div>
    </div>
</main>
<script>
(function () {
    const pathBase = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Request.PathBase.Value ?? ""));
    const api = (path) => (pathBase.endsWith("/") ? pathBase.slice(0, -1) : pathBase) + path;

    const CK_PROFILE = "sites_cp_clone_profile";
    const CK_HOST = "sites_cp_clone_host";
    const CK_USER = "sites_cp_clone_user";
    const CK_PASSWORD = "sites_cp_clone_password";

    function setStatus(msg, ok) {
        const el = document.getElementById("status");
        el.textContent = msg || "";
        el.className = ok === true ? "ok" : ok === false ? "error" : "";
    }

    function cookiePath() {
        const pb = pathBase || "";
        if (!pb || pb === "/") return "/";
        return pb.endsWith("/") ? pb.slice(0, -1) : pb;
    }

    function setCookie(name, value) {
        document.cookie = name + "=" + encodeURIComponent(value || "") + "; path=" + cookiePath()
            + "; max-age=" + (60 * 60 * 24 * 400) + "; SameSite=Lax"
            + (location.protocol === "https:" ? "; Secure" : "");
    }

    function getCookie(name) {
        const prefix = name + "=";
        for (const part of document.cookie.split(";")) {
            const s = part.trim();
            if (s.startsWith(prefix)) return decodeURIComponent(s.slice(prefix.length));
        }
        return "";
    }

    function hydrateCloneCookies() {
        const p = getCookie(CK_PROFILE);
        const h = getCookie(CK_HOST);
        const u = getCookie(CK_USER);
        const pw = getCookie(CK_PASSWORD);
        if (p) document.getElementById("cloneProfile").value = p;
        if (h) document.getElementById("cloneHost").value = h;
        if (u) document.getElementById("cloneUser").value = u;
        if (pw) document.getElementById("clonePassword").value = pw;
    }

    function saveCloneCookies() {
        setCookie(CK_PROFILE, document.getElementById("cloneProfile").value);
        setCookie(CK_HOST, document.getElementById("cloneHost").value);
        setCookie(CK_USER, document.getElementById("cloneUser").value);
        setCookie(CK_PASSWORD, document.getElementById("clonePassword").value);
    }

    async function loadInfo() {
        const res = await fetch(api("/api/system/info"), { credentials: "same-origin" });
        if (!res.ok) return;
        const info = await res.json();
        if (!getCookie(CK_PROFILE))
            document.getElementById("cloneProfile").value = info.profile;
        document.getElementById("cloneDirHint").textContent = "Remote clone dir: " + info.cloneDirectory;
        const hint = document.getElementById("selfUpdateHint");
        if (info.isLinux) {
            hint.innerHTML = '<span class="badge ok">available on this host</span>';
        } else {
            hint.innerHTML = '<span class="badge warn">Windows dev — use on Linux VPS</span>';
            document.getElementById("selfUpdateBtn").disabled = true;
        }
    }

    let clonePollTimer = null;
    document.getElementById("cloneStartBtn").addEventListener("click", async () => {
        saveCloneCookies();
        const body = {
            profile: document.getElementById("cloneProfile").value.trim(),
            host: document.getElementById("cloneHost").value.trim(),
            user: document.getElementById("cloneUser").value.trim(),
            password: document.getElementById("clonePassword").value
        };
        const logEl = document.getElementById("cloneLog");
        logEl.textContent = "";
        if (!body.profile || !body.host || !body.user || !body.password) {
            setStatus("Profile, host, user and password are required.", false);
            return;
        }
        if (body.profile.toLowerCase() === "default") {
            setStatus("Profile 'default' cannot be used for remote clone. Choose a dedicated profile name.", false);
            return;
        }
        try {
            const res = await fetch(api("/api/system/clone"), {
                method: "POST",
                credentials: "same-origin",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || "Clone start failed");
            setStatus("Remote install started…", true);
            if (clonePollTimer) clearInterval(clonePollTimer);
            const runId = data.runId;
            clonePollTimer = setInterval(async () => {
                const st = await fetch(api("/api/system/clone/" + runId), { credentials: "same-origin" });
                if (!st.ok) return;
                const status = await st.json();
                logEl.textContent = (status.log || []).join("\n");
                logEl.scrollTop = logEl.scrollHeight;
                if (status.done) {
                    clearInterval(clonePollTimer);
                    clonePollTimer = null;
                    setStatus(status.error || ("Clone finished with exit code " + status.exitCode),
                        !status.error && status.exitCode === 0);
                }
            }, 1500);
        } catch (e) {
            setStatus(String(e), false);
        }
    });

    document.getElementById("selfUpdateBtn").addEventListener("click", async () => {
        if (!confirm("Schedule self-update? sites-host will restart and the site may be briefly unavailable."))
            return;
        try {
            const res = await fetch(api("/api/system/update"), { method: "POST", credentials: "same-origin" });
            const data = await res.json();
            setStatus(data.message + (data.logPath ? " Log: " + data.logPath : ""), data.succeeded);
        } catch (e) {
            setStatus(String(e), false);
        }
    });

    ["cloneProfile", "cloneHost", "cloneUser", "clonePassword"].forEach(id => {
        document.getElementById(id).addEventListener("change", saveCloneCookies);
    });

    hydrateCloneCookies();
    loadInfo().catch(() => {});
})();
</script>
</body>
</html>
