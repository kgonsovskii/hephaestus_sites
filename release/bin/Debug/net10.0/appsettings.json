{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Sites": "Information"
    }
  },
  "AllowedHosts": "*",
  "Host": {
    "HttpPort": 80,
    "HttpsPort": 443,
    "CertDirectory": "cert",
    "CertPfxFileName": "sites.pfx",
    "CertPfxPassword": ""
  },
  "CertMaintenance": {
    "Enabled": true,
    "AcmeEmail": "admin@example.com",
    "UseStaging": false,
    "TermsOfServiceAgreed": true,
    "CertDirectory": "cert",
    "CertPfxFileName": "sites.pfx",
    "CertPfxPassword": "",
    "RenewBeforeDays": 30,
    "CheckInterval": "12:00:00",
    "StartupDelay": "00:00:15"
  },
  "Sites": {
    "UpstreamRequestTimeout": "00:10:00",
    "Cache": {
      "RootPath": "",
      "MaxEntryBytes": 20971520,
      "HtmlDefaultTtl": "00:10:00",
      "HtmlMaxTtl": "00:15:00",
      "HtmlMinTtl": "00:01:00",
      "ImageTtl": "14.00:00:00",
      "FontTtl": "14.00:00:00",
      "StylesheetTtl": "7.00:00:00",
      "ScriptTtl": "7.00:00:00",
      "DefaultTtl": "06:00:00"
    }
  }
}
